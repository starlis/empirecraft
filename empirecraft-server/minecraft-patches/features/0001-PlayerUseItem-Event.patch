+            isSame = false;
+        }
+        // EMC end - PlayerUseItemEvent
         if (itemStack != resultStack) {
             player.setItemInHand(hand, resultStack);
         }
 
         if (resultStack.isEmpty()) {
             player.setItemInHand(hand, ItemStack.EMPTY);
+            isSame = false; // EMC - PlayerUseItemEvent
