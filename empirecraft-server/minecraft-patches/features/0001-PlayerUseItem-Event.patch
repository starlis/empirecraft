+        if (event.getTempItem() != null) {
+            itemToUse = org.bukkit.craftbukkit.inventory.CraftItemStack.asNMSCopy(event.getTempItem());
+            player.setItemInHand(hand, itemToUse);
+        }
+        InteractionResult result = itemToUse.use(level, player, hand);
+        // EMC end - PlayerUseItemEvent
